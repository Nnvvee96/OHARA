# OHARA — Secrets Configuration
# ─────────────────────────────────────────────────────────────
# 1. Copy this file: cp secrets.example secrets.env
# 2. Fill in every value below
# 3. Never commit secrets.env — it is in .gitignore
# 4. Never paste these values into chat
# ─────────────────────────────────────────────────────────────

# ── HETZNER ──────────────────────────────────────────────────
# hetzner.com → Security → API Tokens → Create Token (Read+Write)
HETZNER_API_TOKEN=your_hetzner_api_token_here

# ── TAILSCALE ────────────────────────────────────────────────
# tailscale.com → Settings → Keys → Generate Auth Key
# Check: Reusable ✓   Ephemeral: NO
TAILSCALE_AUTH_KEY=your_tailscale_auth_key_here

# ── GITHUB ───────────────────────────────────────────────────
# Your GitHub username
GITHUB_USERNAME=your_github_username_here

# github.com → Settings → Developer settings → Personal access tokens
# → Tokens (classic) → Generate new token
# Scopes needed: repo (full)
GITHUB_TOKEN=your_github_pat_here

# ── GEMINI ───────────────────────────────────────────────────
# aistudio.google.com → Get API key → Create API key
# Free tier: 1500 requests/day
GEMINI_API_KEY=your_gemini_api_key_here

# ── SSH ───────────────────────────────────────────────────────
# Path to your SSH public key on your local machine
# Default on Mac/Linux: ~/.ssh/id_rsa.pub or ~/.ssh/id_ed25519.pub
# If you don't have one: ssh-keygen -t ed25519 -C "ohara"
SSH_PUBLIC_KEY_PATH=~/.ssh/id_ed25519.pub

# ── VPS CONFIG ────────────────────────────────────────────────
# Hetzner server type — cx11 is €2.49/mo (cheapest, fine for Phase 1)
# Upgrade to cx21 if scouts are running 5+ domains simultaneously
HETZNER_SERVER_TYPE=cx11
HETZNER_LOCATION=nbg1
# Options: nbg1 (Nuremberg), fsn1 (Falkenstein), hel1 (Helsinki)
# Pick closest to you geographically

# ── OHARA CONFIG ─────────────────────────────────────────────
# How often each scout runs (seconds). 3600 = every hour.
SCOUT_INTERVAL_SECONDS=3600
# Max sources per scout cycle
SCOUT_MAX_SOURCES_PER_CYCLE=10
# Max atoms extracted per source
SCOUT_MAX_ATOMS_PER_SOURCE=5
