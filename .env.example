# OHARA Environment Configuration
# Copy this file to .env and fill in your keys.
# NEVER commit .env to version control.
# NEVER paste keys into chat or code.

# LLM Provider (gemini | anthropic)
LLM_PROVIDER=gemini

# Gemini (free tier — for Phase 1/2)
GEMINI_API_KEY=your_gemini_key_here

# Anthropic (Phase 3+ — swap when ready)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Active model per tier
# Gemini free: gemini-1.5-flash (fast, cheap extraction)
LLM_MODEL_EXTRACTION=gemini-1.5-flash
LLM_MODEL_REASONING=gemini-1.5-pro

# Scout config
SCOUT_CYCLE_DELAY_SECONDS=3
# Delay between source fetches — be a polite crawler
SCOUT_MAX_SOURCES_PER_CYCLE=10
SCOUT_MAX_ATOMS_PER_SOURCE=5
